{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "fileSystem": {
      "allowWrite": [".worktrees/*"]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "crates.io",
        "*.crates.io",
        "static.crates.io",
        "index.crates.io",
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "archive.ubuntu.com",
        "*.archive.ubuntu.com",
        "security.ubuntu.com",
        "ports.ubuntu.com",
        "ftp.riken.jp",
        "ftp.jaist.ac.jp",
        "ftp.tsukuba.wide.ad.jp",
        "ftp.yz.yamagata-u.ac.jp"
      ]
    }
  }
}
